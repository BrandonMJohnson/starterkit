{
  "name": "api-service",
  "root": "services/java/api-service",
  "sourceRoot": "services/java/api-service/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./java-build/gradlew -p java-build :services:java:api-service:build",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./java-build/gradlew -p java-build :services:java:api-service:test",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
