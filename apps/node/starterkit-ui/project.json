{
  "name": "starterkit-ui",
  "root": "apps/node/starterkit-ui",
  "sourceRoot": "apps/node/starterkit-ui/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @starterkit/starterkit-ui build",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @starterkit/starterkit-ui test",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @starterkit/starterkit-ui lint",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
