{
  "name": "policy-service",
  "root": "apps/java/policy-service",
  "sourceRoot": "apps/java/policy-service/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./java-build/gradlew -p java-build :apps:java:policy-service:build",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./java-build/gradlew -p java-build :apps:java:policy-service:test",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
